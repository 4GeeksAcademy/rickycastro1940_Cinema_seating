{
  "name": "typescript-hello",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Hello World with Typescript using Vite and Tailwind CSS",
  "scripts": {
    "start": "vite",
    "dev": "vite",
    "console": "tsx src/main.ts",
    "cinema": "tsx src/cinema-cli.ts",
    "typecheck": "tsc --noEmit",
    "build": "tsc -b && vite build",
    "preview": "vite preview"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.1",
    "@types/node": "^25.6.0",
    "tailwindcss": "^4.2.1",
    "tsx": "^4.19.2",
    "typescript": "^5.6.0",
    "vite": "^5.4.0"
  }
}
